# ==========================================
# BoreSight Environment Configuration
# ==========================================

# ------------------------------------------
# LLM Provider Configuration
# ------------------------------------------
# Provider options: openai, anthropic, ollama, gemini, etc.
LLM_PROVIDER=ollama

# Model options:
# - openai: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# - anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229
# - ollama: gemma3, llama3, mistral
LLM_MODEL=gemma3

# ------------------------------------------
# API Keys (Uncomment and set as needed)
# ------------------------------------------
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# ------------------------------------------
# Validation Loop Settings
# ------------------------------------------
# Enable/disable self-reflection validation step
VALIDATION_ENABLED=true

# Max retries if the LLM validation fails
VALIDATION_MAX_RETRIES=3

# Optional: Override the LLM specifically for validation (e.g. use a smarter model)
# VALIDATOR_PROVIDER=anthropic
# VALIDATOR_MODEL=claude-3-opus-20240229
